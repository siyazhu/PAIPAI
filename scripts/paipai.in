#!/usr/bin/env bash
set -euo pipefail

# Auto-filled by CMake
PREFIX="@CMAKE_INSTALL_PREFIX@"
BINDIR="@CMAKE_INSTALL_FULL_BINDIR@"
MASTER="${BINDIR}/mc_paipai"
PYTHON="@Python3_EXECUTABLE@"
FAST_WORKER="${BINDIR}/fast_worker.py"
SLOW_WORKER="${BINDIR}/slow_worker.py"

# Defaults
INPUT_STRUC="struc.in"
MODEL="GRACE-2L-OMAT"
DEVICE="cpu"
MODE="finiteT"

NUM_FAST=0
NUM_SLOW=1
NGPU=1

MC_STEPS=200000
MC_TEMP=700
POOL_CAP=128
ROOT_DIR="$(pwd)"

P_SWAP_METAL=1
P_SWAP_INTER=1
P_EXCH_METAL=0
P_EXCH_INTER=0
INTSITE_NEIGHBOR_CUTOFF=3.5

MC_EXTRA_ARGS=()

usage() {
cat <<EOF
Usage: paipai [options]

Basic options:
  -i, --input FILE              Initial structure file (default: ${INPUT_STRUC})
  --mode MODE                   search | finiteT (default: ${MODE})
  --model NAME                  MLIP model name (default: ${MODEL})
  --device DEV                  cpu | cuda (default: ${DEVICE})
  --ngpu N                      Number of GPUs for round-robin assignment (default: ${NGPU})
  --root DIR                    Root working directory (default: current directory)

Worker options:
  --fast N                      Number of fast workers (default: ${NUM_FAST})
  --slow N                      Number of slow workers (default: ${NUM_SLOW})
  --pool-cap N                  Waiting-pool capacity (default: ${POOL_CAP})

Monte Carlo options:
  --steps N                     Monte Carlo steps (default: ${MC_STEPS})
  --temp T                      Monte Carlo temperature (default: ${MC_TEMP})
  --p-swap-metal N              Weight for metal swap moves (default: ${P_SWAP_METAL})
  --p-swap-inter N              Weight for interstitial swap moves (default: ${P_SWAP_INTER})
  --p-exch-metal N              Weight for metal exchange moves (default: ${P_EXCH_METAL})
  --p-exch-inter N              Weight for interstitial exchange moves (default: ${P_EXCH_INTER})
  --intsite-neighbor-cutoff X   Cutoff for interstitial-metal neighbor map (default: ${INTSITE_NEIGHBOR_CUTOFF})

Other:
  -h, --help                    Show this help message

Unknown options are passed directly to mc_paipai.
EOF
}

while [[ $# -gt 0 ]]; do
    case "$1" in
        -i|--input) INPUT_STRUC="$2"; shift 2 ;;
        --mode) MODE="$2"; shift 2 ;;
        --model) MODEL="$2"; shift 2 ;;
        --device) DEVICE="$2"; shift 2 ;;
        --ngpu) NGPU="$2"; shift 2 ;;
        --root) ROOT_DIR="$2"; shift 2 ;;

        --fast) NUM_FAST="$2"; shift 2 ;;
        --slow) NUM_SLOW="$2"; shift 2 ;;
        --pool-cap) POOL_CAP="$2"; shift 2 ;;

        --steps) MC_STEPS="$2"; shift 2 ;;
        --temp) MC_TEMP="$2"; shift 2 ;;
        --p-swap-metal) P_SWAP_METAL="$2"; shift 2 ;;
        --p-swap-inter) P_SWAP_INTER="$2"; shift 2 ;;
        --p-exch-metal) P_EXCH_METAL="$2"; shift 2 ;;
        --p-exch-inter) P_EXCH_INTER="$2"; shift 2 ;;
        --intsite-neighbor-cutoff) INTSITE_NEIGHBOR_CUTOFF="$2"; shift 2 ;;

        -h|--help) usage; exit 0 ;;
        --) shift; MC_EXTRA_ARGS+=("$@"); break ;;
        *) MC_EXTRA_ARGS+=("$1"); shift ;;
    esac
done

if [[ "$DEVICE" == "cuda" && "$NGPU" -lt 1 ]]; then
    echo "[ERROR] --ngpu must be >= 1 when --device cuda"
    exit 1
fi

export OMP_NUM_THREADS="${OMP_NUM_THREADS:-1}"
export MKL_NUM_THREADS="${MKL_NUM_THREADS:-1}"
export OPENBLAS_NUM_THREADS="${OPENBLAS_NUM_THREADS:-1}"
export NUMEXPR_NUM_THREADS="${NUMEXPR_NUM_THREADS:-1}"

mkdir -p "$ROOT_DIR/fast" \
         "$ROOT_DIR/waiting_pool" \
         "$ROOT_DIR/waiting_work" \
         "$ROOT_DIR/refine_outbox" \
         "$ROOT_DIR/reports" \
         "$ROOT_DIR/counters" \
         "$ROOT_DIR/mcprocess"

PIDS=()
WORKER_INDEX=0

gpu_for_worker() {
    local idx="$1"
    echo $(( idx % NGPU ))
}

cleanup() {
    echo "[INFO] Cleaning up workers..."
    for pid in "${PIDS[@]:-}"; do
        kill "$pid" 2>/dev/null || true
    done
}
trap cleanup EXIT INT TERM

echo "[INFO] ROOT_DIR = $ROOT_DIR"
echo "[INFO] INPUT_STRUC = $INPUT_STRUC"
echo "[INFO] MODE = $MODE"
echo "[INFO] NUM_FAST = $NUM_FAST, NUM_SLOW = $NUM_SLOW"
echo "[INFO] MODEL = $MODEL, DEVICE = $DEVICE"
echo "[INFO] NGPU = $NGPU"
echo "[INFO] MC_STEPS = $MC_STEPS, MC_TEMP = $MC_TEMP"
echo "[INFO] POOL_CAP = $POOL_CAP"
echo "[INFO] Move weights: swap_metal=$P_SWAP_METAL, swap_inter=$P_SWAP_INTER, exch_metal=$P_EXCH_METAL, exch_inter=$P_EXCH_INTER"
echo "[INFO] INTSITE_NEIGHBOR_CUTOFF = $INTSITE_NEIGHBOR_CUTOFF"

if [[ "$MODE" == "finiteT" ]]; then
    echo "[INFO] finiteT mode: skipping fast workers."
else
    echo "[INFO] Launching $NUM_FAST fast workers..."
    for (( i=1; i<=NUM_FAST; ++i )); do
        LOG_FAST="${ROOT_DIR}/fast_${i}.log"

        if [[ "$DEVICE" == "cuda" ]]; then
            GPU_ID=$(gpu_for_worker "$WORKER_INDEX")
            echo "  -> fast_worker slot $i on GPU $GPU_ID (log: $LOG_FAST)"
            CUDA_VISIBLE_DEVICES="$GPU_ID" "$PYTHON" "$FAST_WORKER" \
                --slot "$i" \
                --root "$ROOT_DIR" \
                --model "$MODEL" \
                --device "$DEVICE" \
                --pool_cap "$POOL_CAP" \
                >"$LOG_FAST" 2>&1 &
        else
            echo "  -> fast_worker slot $i on CPU (log: $LOG_FAST)"
            "$PYTHON" "$FAST_WORKER" \
                --slot "$i" \
                --root "$ROOT_DIR" \
                --model "$MODEL" \
                --device "$DEVICE" \
                --pool_cap "$POOL_CAP" \
                >"$LOG_FAST" 2>&1 &
        fi

        PIDS+=("$!")
        WORKER_INDEX=$((WORKER_INDEX + 1))
    done
fi

echo "[INFO] Launching $NUM_SLOW slow workers..."
for (( j=1; j<=NUM_SLOW; ++j )); do
    ID=$(printf "slow-%02d" "$j")
    LOG_SLOW="${ROOT_DIR}/slow_${ID}.log"

    if [[ "$DEVICE" == "cuda" ]]; then
        GPU_ID=$(gpu_for_worker "$WORKER_INDEX")
        echo "  -> slow_worker $ID on GPU $GPU_ID (log: $LOG_SLOW)"
        CUDA_VISIBLE_DEVICES="$GPU_ID" "$PYTHON" "$SLOW_WORKER" \
            --worker-id "$ID" \
            --root "$ROOT_DIR" \
            --model "$MODEL" \
            --device "$DEVICE" \
            >"$LOG_SLOW" 2>&1 &
    else
        echo "  -> slow_worker $ID on CPU (log: $LOG_SLOW)"
        "$PYTHON" "$SLOW_WORKER" \
            --worker-id "$ID" \
            --root "$ROOT_DIR" \
            --model "$MODEL" \
            --device "$DEVICE" \
            >"$LOG_SLOW" 2>&1 &
    fi

    PIDS+=("$!")
    WORKER_INDEX=$((WORKER_INDEX + 1))
done

echo "[INFO] Running C++ master..."
"$MASTER" "$INPUT_STRUC" \
    --mode "$MODE" \
    --workers "$NUM_FAST" \
    --steps "$MC_STEPS" \
    --temp "$MC_TEMP" \
    --p-swap-metal "$P_SWAP_METAL" \
    --p-swap-inter "$P_SWAP_INTER" \
    --p-exch-metal "$P_EXCH_METAL" \
    --p-exch-inter "$P_EXCH_INTER" \
    --intsite-neighbor-cutoff "$INTSITE_NEIGHBOR_CUTOFF" \
    "${MC_EXTRA_ARGS[@]}"

echo "[INFO] C++ master finished."
